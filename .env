TRAIN_MANUAL_MAPPING_DIR=${TRAIN_RESIZED_DIR}/manual_mappings
TRAIN_MANUAL_PROCESSED_DIR=${TRAIN_MANUAL_MAPPING_DIR}/processed_${TARGET_WIDTH}x${TARGET_HEIGHT}
TRAIN_SPLITS_DIR=${TRAIN_MANUAL_PROCESSED_DIR}/split

