# Base directory
BASE_PATH=/net/projects2/promega/data-analysis

# Core outputs
OUTPUT_FOLDER=/net/projects2/promega/data-analysis/output
PLOTS_FOLDER=${BASE_PATH}/plots
LOGS_FOLDER=${BASE_PATH}/logs
NPY_OUTPUTS=${BASE_PATH}/npy_outputs
PREDICTIONS_DIR=${BASE_PATH}/predictions

# Metadata
META_FILE=/net/projects2/promega/data-analysis/Sample-Tracing.xlsx
SURVEY_RESULTS=${BASE_PATH}/results_surveys

# Resize parameters
TARGET_WIDTH=256
TARGET_HEIGHT=192

# Raw-to-processed image mapping (original images → resized images)
ORIGINAL_MAPPING=${OUTPUT_FOLDER}/image_mapping.json

# Preprocessed dataset (resized images only)
PREPROCESSED_DIR=${OUTPUT_FOLDER}/processed_dataset_${TARGET_WIDTH}x${TARGET_HEIGHT}

# Auto-processed images (from original mapping)
PROCESSED_DATA_DIR=${PREPROCESSED_DIR}/auto_processed

# Manually labeled masks + resized images
MANUAL_MASKS_DIR=${BASE_PATH}/manual_masks
MANUAL_MAPPING_DIR=${PREPROCESSED_DIR}/manual_mappings
MANUAL_PROCESSED_DIR=${MANUAL_MAPPING_DIR}/processed_${TARGET_WIDTH}x${TARGET_HEIGHT}
MANUAL_SPLITS_DIR=${MANUAL_PROCESSED_DIR}/split
MAPPING_PROCESSED_TOTAL=${MANUAL_PROCESSED_DIR}/mapping_processed_total_${TARGET_WIDTH}x${TARGET_HEIGHT}.json

# SegFormer model files
CONFIG_FILE_PATH=${PLOTS_FOLDER}/segformer_masks/20250422_215204/vis_data/config.py
CHECKPOINT_FILE_PATH=${PLOTS_FOLDER}/segformer_masks/iter_1000.pth

# Resize target
TARGET_WIDTH=256
