{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Python Debugger: Current File (Conda Base)",
            "type": "debugpy",
            "request": "launch",
            "program": "${file}",
            "console": "integratedTerminal",
            "python": "/opt/conda/bin/python",
            "env": {
                "CONDA_DEFAULT_ENV": "base" 
            }
        }
    ]
}